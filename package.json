{
  "name": "areti-ai-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.js",
  "author": "Kouskouras D. <kouskourasd@gmail.com>",
  "description": "Areti - Autonomous AI Agent powered by Claude",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "electron:start": "electron .",
    "electron:build": "vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.areti.ai-agent",
    "productName": "Areti AI Agent",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "server.js", "electron.js"],
    "win": { "target": "nsis" },
    "nsis": { "oneClick": false, "allowToChangeInstallationDirectory": true, "createDesktopShortcut": true, "shortcutName": "Areti AI" },
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "express": "^4.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
