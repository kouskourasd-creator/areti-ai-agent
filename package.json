{
  "name": "areti-ai-agent",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron.cjs",
  "author": "Kouskouras D. <kouskourasd@gmail.com>",
  "description": "Areti - Autonomous AI Agent powered by Gemini (free)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server.js",
    "start": "node server.js",
    "electron:start": "npx electron .",
    "electron:build": "vite build && npx electron-builder --win"
  },
  "build": {
    "appId": "com.areti.ai-agent",
    "productName": "Areti AI Agent",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron.cjs"],
    "win": { "target": "nsis" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Areti AI"
    },
    "linux": { "target": "AppImage" },
    "mac": { "target": "dmg" }
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "33.0.0",
    "electron-builder": "25.1.8",
    "typescript": "^5.6.3",
    "vite": "^6.0.7"
  }
}
